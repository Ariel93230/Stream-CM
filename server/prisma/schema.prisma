generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  phone     String?  @unique
  role      String   @default("viewer")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Movie {
  id           String   @id @default(cuid())
  title        String
  description  String
  category     String
  thumbnailUrl String
  videoUrl     String?
  duration     String
  releaseYear  Int
  rating       Float
  isLicensed   Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}
